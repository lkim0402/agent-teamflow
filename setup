#!/usr/bin/env bash
# agent-teamflow setup
# Installs runtime adapters for Claude Code and/or Codex.

set -euo pipefail

INSTALL_DIR="$(cd "$(dirname "$0")" && pwd -P)"
CLAUDE_COMMANDS_DIR="$HOME/.claude/commands"
CODEX_HOME_DIR="${CODEX_HOME:-$HOME/.codex}"
CODEX_SKILLS_DIR="$CODEX_HOME_DIR/skills"

install_claude=false
install_codex=false

usage() {
    cat <<'USAGE'
Usage: ./setup [--all | --claude | --codex]

Options:
  --all      Install Claude Code slash commands and Codex skills (default)
  --claude   Install Claude Code slash commands only
  --codex    Install Codex skills only
  -h, --help Show this help
USAGE
}

if [[ $# -eq 0 ]]; then
    install_claude=true
    install_codex=true
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        --all)
            install_claude=true
            install_codex=true
            ;;
        --claude)
            install_claude=true
            ;;
        --codex)
            install_codex=true
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Error: unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
    shift
done

if [[ ! -f "$INSTALL_DIR/AGENTS.md" ]] || [[ ! -d "$INSTALL_DIR/.claude/commands" ]] || [[ ! -d "$INSTALL_DIR/.codex/skills" ]]; then
    echo "Error: setup must be run from inside the agent-teamflow repo." >&2
    echo "  expected: $INSTALL_DIR/AGENTS.md, $INSTALL_DIR/.claude/commands, and $INSTALL_DIR/.codex/skills" >&2
    exit 1
fi

claude_count=0
codex_skill_count=0

if [[ "$install_claude" == true ]]; then
    mkdir -p "$CLAUDE_COMMANDS_DIR"

    for cmd_file in "$INSTALL_DIR/.claude/commands/"*.md; do
        [[ -f "$cmd_file" ]] || continue
        name=$(basename "$cmd_file")
        output="$CLAUDE_COMMANDS_DIR/$name"

        sed \
            -e "s|\`AGENTS.md\`|\`$INSTALL_DIR/AGENTS.md\`|g" \
            "$cmd_file" > "$output"

        claude_count=$((claude_count + 1))
    done
fi

if [[ "$install_codex" == true ]]; then
    mkdir -p "$CODEX_SKILLS_DIR"
    for skill_dir in "$INSTALL_DIR/.codex/skills/"*; do
        [[ -d "$skill_dir" ]] || continue
        [[ -f "$skill_dir/SKILL.md" ]] || continue
        name=$(basename "$skill_dir")
        output_dir="$CODEX_SKILLS_DIR/$name"

        mkdir -p "$output_dir"
        sed \
            -e "s|\`AGENTS.md\`|\`$INSTALL_DIR/AGENTS.md\`|g" \
            "$skill_dir/SKILL.md" > "$output_dir/SKILL.md"

        if [[ -d "$skill_dir/agents" ]]; then
            rm -rf "$output_dir/agents"
            cp -R "$skill_dir/agents" "$output_dir/agents"
        fi

        codex_skill_count=$((codex_skill_count + 1))
    done

    if [[ "$codex_skill_count" -eq 0 ]]; then
        echo "Error: no Codex skills found under $INSTALL_DIR/.codex/skills" >&2
        exit 1
    fi
fi

echo "agent-teamflow setup complete"
if [[ "$install_claude" == true ]]; then
    echo "  Claude Code commands: $claude_count installed into $CLAUDE_COMMANDS_DIR/"
fi
if [[ "$install_codex" == true ]]; then
    echo "  Codex skills: $codex_skill_count installed into $CODEX_SKILLS_DIR/"
fi
echo ""
echo "Next steps:"
echo "  1. Open your agent inside any repo you want to use this in."
echo "  2. Run /teamflow-init to configure that repo (writes .agent-teamflow)."
echo "  3. Then try /issue in Claude Code, or pick the issue skill from /skills in Codex."
echo ""
echo "Update later: cd $INSTALL_DIR && git pull && ./setup"
if [[ "$install_claude" == true ]]; then
    echo "Uninstall Claude commands: rm $CLAUDE_COMMANDS_DIR/{$(ls "$INSTALL_DIR/.claude/commands/" | sed 's/\.md$//' | paste -sd',' -)}.md"
fi
if [[ "$install_codex" == true ]]; then
    echo "Uninstall Codex skills:   rm -rf $CODEX_SKILLS_DIR/{$(find "$INSTALL_DIR/.codex/skills" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | paste -sd',' -)}"
fi
