#!/usr/bin/env bash
# agent-teamflow setup
# Installs runtime prompts/commands for Claude Code and/or Codex.

set -euo pipefail

INSTALL_DIR="$(cd "$(dirname "$0")" && pwd -P)"
CLAUDE_COMMANDS_DIR="$HOME/.claude/commands"
CODEX_PROMPTS_DIR="${CODEX_HOME:-$HOME/.codex}/prompts"

install_claude=false
install_codex=false

usage() {
    cat <<'USAGE'
Usage: ./setup [--all | --claude | --codex]

Options:
  --all      Install Claude Code slash commands and Codex prompts (default)
  --claude   Install Claude Code slash commands only
  --codex    Install Codex prompts only
  -h, --help Show this help
USAGE
}

if [[ $# -eq 0 ]]; then
    install_claude=true
    install_codex=true
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        --all)
            install_claude=true
            install_codex=true
            ;;
        --claude)
            install_claude=true
            ;;
        --codex)
            install_codex=true
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Error: unknown option: $1" >&2
            usage >&2
            exit 1
            ;;
    esac
    shift
done

if [[ ! -d "$INSTALL_DIR/skills" ]] || [[ ! -f "$INSTALL_DIR/AGENTS.md" ]] || [[ ! -d "$INSTALL_DIR/.claude/commands" ]] || [[ ! -d "$INSTALL_DIR/.codex/prompts" ]]; then
    echo "Error: setup must be run from inside the agent-teamflow repo." >&2
    echo "  expected: $INSTALL_DIR/skills, $INSTALL_DIR/AGENTS.md, $INSTALL_DIR/.claude/commands, and $INSTALL_DIR/.codex/prompts" >&2
    exit 1
fi

claude_count=0
codex_count=0

if [[ "$install_claude" == true ]]; then
    if [[ ! -d "$INSTALL_DIR/.claude/commands" ]]; then
        echo "Error: missing Claude commands at $INSTALL_DIR/.claude/commands" >&2
        exit 1
    fi

    mkdir -p "$CLAUDE_COMMANDS_DIR"

    for cmd_file in "$INSTALL_DIR/.claude/commands/"*.md; do
        [[ -f "$cmd_file" ]] || continue
        name=$(basename "$cmd_file")
        output="$CLAUDE_COMMANDS_DIR/$name"

        sed \
            -e "s|\`AGENTS.md\`|\`$INSTALL_DIR/AGENTS.md\`|g" \
            -e "s|\`skills/|\`$INSTALL_DIR/skills/|g" \
            "$cmd_file" > "$output"

        claude_count=$((claude_count + 1))
    done
fi

if [[ "$install_codex" == true ]]; then
    if [[ ! -d "$INSTALL_DIR/.codex/prompts" ]]; then
        echo "Error: missing Codex prompts at $INSTALL_DIR/.codex/prompts" >&2
        exit 1
    fi

    mkdir -p "$CODEX_PROMPTS_DIR"
    for prompt_file in "$INSTALL_DIR/.codex/prompts/"*.md; do
        [[ -f "$prompt_file" ]] || continue
        name=$(basename "$prompt_file")
        output="$CODEX_PROMPTS_DIR/$name"

        sed \
            -e "s|\`AGENTS.md\`|\`$INSTALL_DIR/AGENTS.md\`|g" \
            -e "s|\`skills/|\`$INSTALL_DIR/skills/|g" \
            "$prompt_file" > "$output"

        codex_count=$((codex_count + 1))
    done
fi

echo "agent-teamflow setup complete"
if [[ "$install_claude" == true ]]; then
    echo "  Claude Code commands: $claude_count installed into $CLAUDE_COMMANDS_DIR/"
fi
if [[ "$install_codex" == true ]]; then
    echo "  Codex prompts: $codex_count installed into $CODEX_PROMPTS_DIR/"
fi
echo ""
echo "Next steps:"
echo "  1. Open your agent inside any repo you want to use this in."
echo "  2. Run /teamflow-init to configure that repo (writes .agent-teamflow)."
echo "  3. Then try /issue, /dispatch, or /resolve."
echo ""
echo "Update later: cd $INSTALL_DIR && git pull && ./setup"
echo "Uninstall Claude commands: rm $CLAUDE_COMMANDS_DIR/{$(ls "$INSTALL_DIR/.claude/commands/" | sed 's/\.md$//' | paste -sd',' -)}.md"
echo "Uninstall Codex prompts:  rm $CODEX_PROMPTS_DIR/{$(ls "$INSTALL_DIR/.codex/prompts/" | sed 's/\.md$//' | paste -sd',' -)}.md"
